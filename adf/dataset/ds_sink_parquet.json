{
	"name": "ds_sink_parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_adls_olist",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"sink_folder": {
				"type": "string"
			},
			"sink_prefix": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().sink_prefix, '_', formatDateTime(utcnow(), 'yyyyMMdd'), '.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@dataset().sink_folder",
					"type": "Expression"
				},
				"fileSystem": "raw"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}